{
  "name": "@llm-agent/gateway",
  "version": "0.1.0",
  "private": true,
  "description": "API gateway publica. Orquesta conversation-service y llm-worker para servir POST /chat.",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
