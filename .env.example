# ============================================
# Plantilla de variables de entorno
# Copiar como .env y rellenar con valores reales:
#   cp .env.example .env
# NUNCA commitear .env
# ============================================

# ============================================
# General
# ============================================
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# Puertos de los microservicios (locales)
# ============================================
GATEWAY_PORT=3000
CONVERSATION_PORT=3001
LLM_WORKER_PORT=3002

# ============================================
# URLs internas (docker-compose / kubernetes overriden en runtime)
# ============================================
CONVERSATION_SERVICE_URL=http://localhost:3001
LLM_WORKER_URL=http://localhost:3002

# ============================================
# Base de datos (PostgreSQL)
# Puerto 5433 en local para no chocar con Postgres del sistema
# ============================================
DATABASE_URL=postgresql://conversa:conversa@localhost:5433/conversa?schema=public

# ============================================
# LLM Provider
# mock      -> respuestas hardcoded, sin llamadas externas (dev sin API key)
# anthropic -> Claude API directo (requiere ANTHROPIC_API_KEY)
# bedrock   -> AWS Bedrock (requiere credenciales AWS — Fase 7)
# ============================================
LLM_PROVIDER=mock

# Anthropic (solo si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXX-reemplazar-con-clave-real
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=512

# AWS Bedrock (solo si LLM_PROVIDER=bedrock, Fase 7)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-v1:0

# ============================================
# JWT / Auth (stub por ahora, Fase 1)
# ============================================
JWT_SECRET=cambiar-por-un-secret-largo-y-aleatorio-al-menos-32-caracteres
JWT_EXPIRES_IN=15m

# ============================================
# Observabilidad (se activa en Fase 3)
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=conversa-mesh

# ============================================
# Resiliencia (opossum circuit breakers, Fase 4)
# ============================================
CB_TIMEOUT_MS=5000
CB_ERROR_THRESHOLD=50
CB_RESET_TIMEOUT_MS=30000
